flowchart LR
  classDef root fill:#111827,stroke:#f59e0b,stroke-width:2.5px,color:#f8fafc;
  classDef branchA fill:#111827,stroke:#60a5fa,stroke-width:2px,color:#eff6ff;
  classDef branchB fill:#111827,stroke:#34d399,stroke-width:2px,color:#ecfdf5;
  classDef branchC fill:#111827,stroke:#f59e0b,stroke-width:2px,color:#fff7ed;
  classDef branchD fill:#111827,stroke:#e879f9,stroke-width:2px,color:#fdf4ff;
  classDef leafA fill:#0b1220,stroke:#60a5fa,stroke-width:1.5px,color:#dbeafe;
  classDef leafB fill:#0b1220,stroke:#34d399,stroke-width:1.5px,color:#dcfce7;
  classDef leafC fill:#0b1220,stroke:#f59e0b,stroke-width:1.5px,color:#ffedd5;
  classDef leafD fill:#0b1220,stroke:#e879f9,stroke-width:1.5px,color:#fae8ff;
  classDef note fill:#111827,stroke:#facc15,stroke-width:1.5px,color:#f8fafc;

  ROOT["Chilllink<br/>User Stories"]:::root
  ACCOUNT["Account management"]:::branchA
  WORKSPACE["Workspace management"]:::branchB
  CHANNEL["Channel management"]:::branchC
  MESSAGING["Messaging"]:::branchD

  linkStyle default stroke:#94a3b8,stroke-width:2px;

  ROOT --- ACCOUNT
  ROOT --- WORKSPACE
  ROOT --- CHANNEL
  ROOT --- MESSAGING

  A1["Register"]:::leafA
  A2["Log in"]:::leafA
  A3["Manage profile"]:::leafA
  A4["Log out"]:::leafA
  ACCOUNT --- A1
  ACCOUNT --- A2
  ACCOUNT --- A3
  ACCOUNT --- A4

  W1["Browse workspaces"]:::leafB
  W2["Create workspace"]:::leafB
  W3["Rename workspace"]:::leafB
  W4["Delete workspace"]:::leafB
  W5["View workspace members"]:::leafB
  W6["Add workspace member"]:::leafB
  W7["Remove workspace member"]:::leafB
  WORKSPACE --- W1
  WORKSPACE --- W2
  WORKSPACE --- W3
  WORKSPACE --- W4
  WORKSPACE --- W5
  WORKSPACE --- W6
  WORKSPACE --- W7

  C1["Browse channels"]:::leafC
  C2["Create channel"]:::leafC
  C3["Rename channel"]:::leafC
  C4["Delete channel"]:::leafC
  C5["View channel members"]:::leafC
  C6["Add channel member"]:::leafC
  C7["Remove channel member"]:::leafC
  CHANNEL --- C1
  CHANNEL --- C2
  CHANNEL --- C3
  CHANNEL --- C4
  CHANNEL --- C5
  CHANNEL --- C6
  CHANNEL --- C7

  M1["Read messages"]:::leafD
  M2["Send message"]:::leafD
  M3["Receive real-time updates"]:::leafD
  M4["Restricted channel access"]:::leafD
  MESSAGING --- M1
  MESSAGING --- M2
  MESSAGING --- M3
  MESSAGING --- M4

  TEMPLATE["As a [user]<br/>I want [goal]<br/>so that [benefit]."]:::note
  ROOT -.-> TEMPLATE
