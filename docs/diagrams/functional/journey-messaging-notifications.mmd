%%{init: {
  "theme":"base",
  "themeVariables":{
    "background":"#050816",
    "primaryColor":"#0f172a",
    "primaryBorderColor":"#f59e0b",
    "primaryTextColor":"#f8fafc",
    "secondaryColor":"#0f172a",
    "secondaryBorderColor":"#60a5fa",
    "secondaryTextColor":"#f8fafc",
    "tertiaryColor":"#0f172a",
    "tertiaryBorderColor":"#34d399",
    "tertiaryTextColor":"#f8fafc",
    "lineColor":"#94a3b8",
    "textColor":"#f8fafc"
  },
  "flowchart":{"curve":"basis"}
}}%%
flowchart LR
  classDef root fill:#111827,stroke:#f59e0b,stroke-width:2.5px,color:#f8fafc;
  classDef stepA fill:#111827,stroke:#60a5fa,stroke-width:2px,color:#eff6ff;
  classDef stepB fill:#111827,stroke:#34d399,stroke-width:2px,color:#ecfdf5;
  classDef stepC fill:#111827,stroke:#f59e0b,stroke-width:2px,color:#fff7ed;
  classDef warn fill:#2a0f12,stroke:#ef4444,stroke-width:1.5px,color:#fee2e2;
  classDef note fill:#0b1220,stroke:#a855f7,stroke-width:1.5px,color:#f3e8ff;

  subgraph FLOW["USER JOURNEY - MESSAGING & NOTIFICATIONS"]
    direction TB
    A["Open a channel"]:::stepA
    B["Load messages history"]:::stepB
    C["Type message"]:::stepA
    D["POST /api/messages"]:::stepB
    E["Persist message (DB)"]:::stepC
    F["Publish Mercure update"]:::stepB
    G["Clients receive SSE"]:::stepA
    H["UI updates in real-time"]:::stepC
    I["Optional: typing indicator"]:::stepA
    J["Publish typing event"]:::stepB
    K["Show typing state"]:::stepC

    A --> B --> C --> D --> E --> F --> G --> H
    H --> I --> J --> K
  end

  N["Notifications: real-time via Mercure"]:::note
  FLOW --- N
