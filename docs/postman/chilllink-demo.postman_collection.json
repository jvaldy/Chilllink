{
  "info": {
    "_postman_id": "0a4f7d54-b148-4dc3-bfe2-8d35d59f9f9b",
    "name": "Chilllink Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Demo scenario for presentation: JWT authentication, workspace ownership, channel access control, and business rule enforcement."
  },
  "item": [
    {
      "name": "1. Register owner",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{$randomUUID}}-owner@demo.test\",\n  \"password\": \"DemoPass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = JSON.parse(pm.request.body.raw);",
              "pm.environment.set('ownerEmail', body.email);",
              "pm.environment.set('defaultPassword', body.password);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
