    {
      "name": "7. Owner creates workspace",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Demo Workspace\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/workspaces",
          "host": ["{{baseUrl}}"],
          "path": ["api", "workspaces"]
        }
      },
      "event": [
